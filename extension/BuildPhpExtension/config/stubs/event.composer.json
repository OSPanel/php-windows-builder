{
    "require":
    {
        "openssl": "*",
        "pthreads": "*",
        "libevent": "*"
    },
    "php-ext":
    {
        "configure-options": [
        {
            "name": "with-event"
        },
        {
            "name": "with-event-pthreads"
        },
        {
            "name": "with-event-openssl"
        },
        {
            "name": "with-event-extra=yes"
        },
        {
            "name": "enable-event-sockets"
        }]
    }
}